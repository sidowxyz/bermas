# Twilio Configuration
# Get these values from your Twilio Console: https://console.twilio.com/

# Your Twilio Account SID
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Twilio Auth Token  
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Twilio Phone Number (must be verified in trial account)
TWILIO_PHONE_NUMBER=+1234567890

# Instructions:
# 1. Copy this file to .env
# 2. Replace the xxx values with your actual Twilio credentials
# 3. For Somalia numbers, use format: +252XXXXXXXXX
# 4. For US numbers, use format: +1XXXXXXXXXX
